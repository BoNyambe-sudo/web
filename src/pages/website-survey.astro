---
import Layout from "@/layouts/Layout.astro";
import ScrollToTop from "@/components/ScrollToTop.astro";
import PrimalSurvey from "@/components/PrimalSurvey.tsx";
import { SITE_URL, SITE_DESCRIPTION } from "@/lib/seoConfig";
---

<Layout
  title="Website Survey"
  description="Take our quick website survey and discover how a website can transform your business. Get personalized insights in minutes."
  keywords="website survey, business assessment, website audit, digital transformation, web development consultation"
  canonical={`${SITE_URL}website-survey/`}
>
  <ScrollToTop />
  <PrimalSurvey client:load />
</Layout>
