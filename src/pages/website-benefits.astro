---
import Layout from "@/layouts/Layout.astro";
import Logo from "@/components/Logo.astro";
import ScrollToTop from "@/components/ScrollToTop.astro";
import { SITE_URL, SITE_DESCRIPTION } from "@/lib/seoConfig";
import {
  ShieldCheck,
  TrendingUp,
  Award,
  Gauge,
  ArrowLeft,
  Users,
  BarChart3,
  Globe,
  Zap,
} from "lucide-react";

const TESTIMONIALS = [
  {
    quote:
      "After launching our website, leads increased by 40% in the first month.",
    author: "Sarah M.",
    role: "Restaurant Owner",
    initials: "SM",
  },
  {
    quote: "We went from invisible online to ranking #1 for our core keywords.",
    author: "James K.",
    role: "Consultant",
    initials: "JK",
  },
  {
    quote:
      "Our competitors have websites. We now have a dominant digital presence.",
    author: "Elena R.",
    role: "Real Estate Agent",
    initials: "ER",
  },
];
const CLIENT_LOGOS = ["Acme", "Vertex", "Novus", "Prism", "Forge", "Lumen"];
const benefitIcon = (name: string) => {
  const icons: Record<string, string> = {
    "trending-up":
      '<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>',
    gauge: '<path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/>',
    globe:
      '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>',
    zap: '<path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>',
    shield:
      '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>',
    "bar-chart":
      '<line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/>',
    award:
      '<path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526"/><circle cx="12" cy="8" r="6"/>',
  };
  return icons[name] ?? "";
};
const costBenefits = [
  {
    title: "Lost Revenue",
    description:
      "Invisible = Unexistent. 57% of buyers will not consider a business without a website. That is more than half your market walking away.",
    icon: "trending-up",
  },
  {
    title: "Stagnation",
    description:
      "Not Growing While Competitors Surge. While you wait, competitors with websites capture leads, build authority, and scale faster.",
    icon: "gauge",
  },
  {
    title: "Irrelevance",
    description:
      "Missing 57% Who Search Before Buying. Without a site, you are absent from the most important decision moment in the buyer journey.",
    icon: "globe",
  },
  {
    title: "Overwhelm",
    description:
      "Social Media Algorithms Control You. Relying on social media alone means your reach is dictated by platforms you do not own.",
    icon: "zap",
  },
];
const drivers = [
  {
    title: "Security",
    description:
      "Own Your Digital Land, Not Rent. Your website is your sovereign territory. No algorithm changes, no shadowbans, no platform rules.",
    icon: "shield",
  },
  {
    title: "Profit",
    description:
      "Your 24/7 Automated Revenue Team. While you sleep, your site qualifies leads, demonstrates value, and converts visitors into buyers.",
    icon: "bar-chart",
  },
  {
    title: "Status",
    description:
      "84% Trust Businesses With Websites. A professional site is a credibility signal that separates serious players from side hustles.",
    icon: "award",
  },
  {
    title: "Control",
    description:
      "Your Narrative, Your Rules, Always. You decide the message, the design, the journey. No middleman. No compromises.",
    icon: "gauge",
  },
];
---

<Layout
  title="Claim Your Digital Dominance"
  description="Stop bleeding customers to competitors. Book a free consultation and discover how to unlock 24/7 automated revenue with a high-performance website."
  keywords="website consultation, digital dominance, business growth, free consultation, web development, NestJS Angular developer, web development, Web development services in Zambia,SEO web design, performance optimization, Zambia web developer, website development Zambia, website design Zambia, software development Zambia, web developer Lusaka, responsive web design, ecommerce website Zambia, SEO services Zambia, custom software development, WordPress development Zambia"
  canonical={`${SITE_URL}website-benefits/`}
  type="website"
>
  <ScrollToTop />
  <div class="min-h-screen bg-background">
    <nav
      class="sticky top-0 z-40 border-b border-border/60 bg-background/80 backdrop-blur-md"
    >
      <div
        class="mx-auto max-w-6xl px-4 sm:px-6 h-14 flex items-center justify-between"
      >
        <a
          href="/web/"
          class="inline-flex items-center gap-2 text-sm font-medium rounded-md px-2 py-1 hover:bg-muted"
        >
          <ArrowLeft className="size-4" />Back
        </a>
        <div class="flex items-center gap-1">
          <Logo size={24} /><span class="text-sm font-semibold tracking-tight"
            >Bo Nyambe</span
          >
        </div>
        <div class="w-16"></div>
      </div>
    </nav>

    <main class="mx-auto max-w-6xl px-4 sm:px-6">
      <section class="py-16 sm:py-24 text-center space-y-6 reveal">
        <h1
          class="text-3xl sm:text-5xl md:text-6xl font-black tracking-tight leading-[1.1]"
        >
          Claim Your <span class="text-primary">Digital Dominance</span>
        </h1>
        <p
          class="text-base sm:text-lg text-muted-foreground max-w-2xl mx-auto leading-relaxed"
        >
          Stop Bleeding Customers to Competitors. Build a high-performance
          website that works 24/7 — while you sleep, while you close deals,
          while you scale.
        </p>
        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-3 pt-2"
        >
          <a
            href="/web/website-survey/"
            class="inline-flex h-12 items-center justify-center rounded-lg bg-primary px-8 text-base font-semibold text-primary-foreground shadow-lg transition hover:bg-primary/80"
            >Book a Call</a
          >
        </div>
        <p class="text-xs text-muted-foreground">
          Limited consultation slots — early adopters win.
        </p>
      </section>

      <section class="py-12 sm:py-16 space-y-8">
        <div class="text-center space-y-2">
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">
            The Cost of <span class="text-destructive">Absence</span>
          </h2>
          <p class="text-sm text-muted-foreground max-w-xl mx-auto">
            Every day without a professional website is a day your competitors
            are winning. Here is what that actually costs you.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {
            costBenefits.map((b) => (
              <div class="rounded-xl border border-border/50 bg-card p-6 reveal">
                <div
                  class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary mb-3"
                  set:html={`<svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${benefitIcon(b.icon)}</svg>`}
                />
                <h3 class="font-semibold mb-1">{b.title}</h3>
                <p class="text-sm leading-7 text-muted-foreground">
                  {b.description}
                </p>
              </div>
            ))
          }
        </div>
      </section>

      <section class="py-12 sm:py-16 space-y-8">
        <div class="text-center space-y-2">
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">
            The 4 Primal Drivers
          </h2>
          <p class="text-sm text-muted-foreground max-w-xl mx-auto">
            A website is not just a page — it is a strategic asset that taps
            into the core motivations of your customers.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {
            drivers.map((b) => (
              <div class="rounded-xl border border-border/50 bg-card p-6 reveal">
                <div
                  class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary mb-3"
                  set:html={`<svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${benefitIcon(b.icon)}</svg>`}
                />
                <h3 class="font-semibold mb-1">{b.title}</h3>
                <p class="text-sm leading-7 text-muted-foreground">
                  {b.description}
                </p>
              </div>
            ))
          }
        </div>
      </section>

      <section class="py-12 sm:py-16 space-y-10">
        <div class="text-center space-y-2">
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">
            Trusted by People Who Demand Results
          </h2>
          <p class="text-sm text-muted-foreground max-w-xl mx-auto">
            Real outcomes from businesses that chose to stop bleeding customers
            and start scaling with a professional website.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {
            TESTIMONIALS.map((t) => (
              <div class="rounded-xl border border-border/60 bg-card p-6 space-y-4 transition-colors hover:border-primary/20 reveal">
                <p class="text-sm text-foreground leading-relaxed">
                  "{t.quote}"
                </p>
                <div class="flex items-center gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 text-primary text-xs font-bold">
                    {t.initials}
                  </div>
                  <div>
                    <>
                      <p class="text-sm font-semibold">{t.author}</p>
                      <p class="text-xs text-muted-foreground">{t.role}</p>
                    </>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
        <div class="space-y-4">
          <p
            class="text-center text-xs font-medium text-muted-foreground uppercase tracking-widest"
          >
            Trusted across industries
          </p>
          <div
            class="flex flex-wrap items-center justify-center gap-8 opacity-60"
          >
            {
              CLIENT_LOGOS.map((logo) => (
                <span class="text-lg font-bold tracking-tight text-muted-foreground">
                  {logo}
                </span>
              ))
            }
          </div>
        </div>
      </section>

      <section class="py-12 sm:py-20">
        <div
          class="rounded-2xl border border-border/60 bg-gradient-to-b from-muted/30 to-background p-8 sm:p-12 text-center space-y-6 reveal"
        >
          <div
            class="inline-flex items-center gap-2 rounded-full bg-primary/10 px-4 py-1.5 text-xs font-semibold text-primary"
          >
            <Users className="size-3.5" />Limited Spots — Early Adopters Win
          </div>
          <h2 class="text-2xl sm:text-4xl font-black tracking-tight">
            Ready to own your digital presence?
          </h2>
          <p
            class="text-sm sm:text-base text-muted-foreground max-w-xl mx-auto leading-relaxed"
          >
            Stop watching competitors take your market share. Book a free
            consultation now and get a clear, actionable roadmap to digital
            dominance.
          </p>
          <div
            class="flex flex-col sm:flex-row items-center justify-center gap-3 pt-2"
          >
            <a
              href="/web/website-survey/"
              class="inline-flex h-14 items-center justify-center rounded-lg bg-primary px-10 text-lg font-bold text-primary-foreground shadow-xl transition hover:bg-primary/80"
              >Book a Call</a
            >
          </div>
          <p class="text-xs text-muted-foreground">
            No commitment. No pitch. Just actionable insights delivered in 48
            hours.
          </p>
        </div>
      </section>
    </main>
  </div>

  <script is:inline>
    (function () {
      const els = document.querySelectorAll(".reveal");
      if (!("IntersectionObserver" in window)) {
        els.forEach((el) => el.classList.add("revealed"));
        return;
      }
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("revealed");
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.1 },
      );
      els.forEach((el) => io.observe(el));
    })();
  </script>

  <style>
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition:
        opacity 0.6s ease-out,
        transform 0.6s ease-out;
    }
    .reveal.revealed {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
</Layout>
