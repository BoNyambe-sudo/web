---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ScrollToTop from "@/components/ScrollToTop.astro";
import BlogRenderer from "@/components/BlogRenderer.astro";
import BlogCard from "@/components/BlogCard.astro";
import { fetchBlogs, fetchBlog, type BlogType } from "@/lib/api";
import { SITE_URL, getBlogPostSchema, getBreadcrumbSchema } from "@/lib/seoConfig";
import { formatDateShort } from "@/lib/formattedDate";
import { formatCompactNumber } from "@/lib/utils";

export async function getStaticPaths() {
  try {
    const res = await fetchBlogs({ published: true, deleted: false, limit: 100, page: 1 });
    const blogs = res.data || [];
    return blogs.map((blog: BlogType) => ({
      params: { slug: blog.slug },
      props: { blog },
    }));
  } catch (e) {
    console.error("Failed to fetch blogs for SSG:", e);
    return [];
  }
}

interface Props {
  blog: BlogType;
}
const { blog } = Astro.props;

const canonical = `${SITE_URL}blog/${blog.slug}`;
const schema = getBlogPostSchema(blog);
const breadcrumb = getBreadcrumbSchema([
  { name: "Home", url: SITE_URL },
  { name: "Blog", url: `${SITE_URL}blog` },
  { name: blog.title, url: canonical },
]);

let similar: BlogType[] = [];
try {
  const sim = await fetchBlogs({
    published: true,
    deleted: false,
    category: blog.category,
    limit: 4,
    page: 1,
  });
  similar = (sim.data || []).filter((b) => b.slug !== blog.slug).slice(0, 3);
} catch {}

const authorName = `${blog.author?.firstName || ""} ${blog.author?.lastName || ""}`.trim() || "Bo Nyambe";
---

<Layout
  title={blog.title}
  description={blog.description || blog.title}
  keywords={`${blog.category}, ${blog.tags?.join(", ") || ""}, blog, article`}
  image={blog.thumbnail}
  type="article"
  canonical={canonical}
>
  <ScrollToTop />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  <Header />
  <div class="container py-10">
    <nav class="flex items-center gap-2 text-sm text-muted-foreground mb-6" aria-label="Breadcrumb">
      <a href="/web/" class="hover:text-primary">Home</a>
      <span>/</span>
      <a href="/web/blog" class="hover:text-primary">Blog</a>
      <span>/</span>
      <span class="text-foreground">{blog.title}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      <div class="lg:col-span-3">
        <div class="mb-8">
          <div class="flex items-center gap-4 mb-4">
            <span class="px-3 py-1 bg-primary/10 text-primary rounded-full text-sm font-medium">{blog.category}</span>
            <div class="flex text-sm md:text-base items-center gap-1 text-muted-foreground">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <span>{blog.readTime} min read</span>
            </div>
            {blog.views !== undefined && (
              <div class="flex text-sm md:text-base items-center gap-1 text-muted-foreground">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
                <span>{formatCompactNumber(blog.views)} {blog.views === 1 ? "view" : "views"}</span>
              </div>
            )}
          </div>
          <h1 class="text-3xl lg:text-4xl font-bold mb-4">{blog.title}</h1>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center font-semibold text-primary">
              {authorName.split(" ").map((n) => n[0]).join("").toUpperCase()}
            </div>
            <div>
              <p class="font-medium">{authorName}</p>
              <p class="text-sm text-muted-foreground">{formatDateShort(blog.createdAt)}</p>
            </div>
          </div>
        </div>

        <BlogRenderer htmlContent={blog.content} />

        <div class="mt-8">
          <div class="flex items-center gap-2 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground"><path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/></svg>
            <span class="font-medium">Tags</span>
          </div>
          <div class="flex flex-wrap gap-2">
            {blog.tags?.map((tag) => (
              <span class="px-3 py-1 bg-muted rounded-full text-sm text-muted-foreground hover:bg-primary/10 hover:text-primary transition-colors">{tag}</span>
            ))}
          </div>
        </div>

        {similar.length > 0 && (
          <div class="mt-12">
            <div class="flex items-center gap-2 mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z"/><polyline points="14 2 14 8 20 8"/></svg>
              <h2 class="text-2xl font-bold">Similar Blog Posts</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {similar.map((b) => <BlogCard blog={b} />)}
            </div>
          </div>
        )}
      </div>

      <aside class="lg:col-span-1">
        <div class="sticky top-20 space-y-6">
          <div class="rounded-xl border border-primary/20 bg-linear-to-br from-primary/5 to-background p-6 animate-sidebar-pulse">
            <div class="flex items-center gap-2 text-base font-semibold mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              Unlock Your Digital Potential
            </div>
            <p class="text-sm text-muted-foreground mb-4">A powerful website is the ultimate weapon for wealth, credibility, and unstoppable growth. Discover why your business cannot afford to be left behind.</p>
            <a href="/web/website-benefits" class="inline-flex w-full items-center justify-center rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground transition hover:bg-primary/80">
              Explore Website Benefits
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
          <div class="rounded-xl border border-primary/20 bg-linear-to-br from-primary/5 to-background p-6 animate-sidebar-pulse">
            <div class="flex items-center gap-2 text-base font-semibold mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
              Shape Your Digital Future
            </div>
            <p class="text-sm text-muted-foreground mb-4">Take our quick survey and discover how a website can transform your business. Get personalized insights in minutes.</p>
            <a href="/web/website-survey" class="inline-flex w-full items-center justify-center rounded-lg border border-border px-4 py-2 text-sm font-semibold transition hover:bg-muted">
              Take the Survey
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>
  <Footer />
</Layout>
