---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ScrollToTop from "@/components/ScrollToTop.astro";
import BlogCard from "@/components/BlogCard.astro";
import BlogFilters from "@/components/BlogFilters.tsx";
import { fetchBlogs, fetchTopTags, type BlogType } from "@/lib/api";
import {
  SITE_URL,
  BLOG_CATEGORIES,
  getBlogListSchema,
  getDescriptionForCategory,
  getKeywordsForCategory,
} from "@/lib/seoConfig";

let initialBlogs: BlogType[] = [];
let availableTags: string[] = [];
try {
  const res = await fetchBlogs({
    published: true,
    deleted: false,
    sortBy: "-views",
    limit: 12,
    page: 1,
  });
  initialBlogs = res.data || [];
} catch (e) {
  console.error("Failed to fetch initial blogs:", e);
}
try {
  const tags = await fetchTopTags();
  availableTags = tags.tags || [];
} catch (e) {
  console.error("Failed to fetch top tags:", e);
}

const blogListSchema = getBlogListSchema(undefined, initialBlogs.length);
const pageTitle = "Explore Blog";
const pageDescription =
  "Explore insightful articles on Technology, Lifestyle, Health, Photography, Sports, Business, and more. Read latest blog posts and expert insights.";
const pageKeywords = [
  ...BLOG_CATEGORIES,
  "blog",
  "articles",
  "latest posts",
  "expert insights",
  "NestJS Angular developer",
  "web development",
  "Web development services in Zambia",
  "SEO web design",
  "performance optimization",
  "Zambia web developer",
  "website development Zambia",
  "website design Zambia",
  "software development Zambia",
  "web developer Lusaka",
  "responsive web design",
  "ecommerce website Zambia",
  "SEO services Zambia",
  "custom software development",
  "WordPress development Zambia",
].join(", ");
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  canonical={`${SITE_URL}blog/`}
>
  <ScrollToTop />
  <script
    type="application/ld+json"
    set:html={JSON.stringify(blogListSchema)}
  />
  <Header />
  <main class="container py-10">
    <div class="mb-8 space-y-4">
      <div class="space-y-2">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-primary">
          Insights & ideas
        </p>
        <h1 class="text-2xl font-bold">Blog</h1>
        <p class="max-w-2xl text-sm text-muted-foreground">
          Use the filters and sorting controls only when you want a curated
          list.
        </p>
      </div>

      {
        initialBlogs.length > 0 ? (
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
            {initialBlogs.slice(0, 10).map((blog) => (
              <BlogCard blog={blog} />
            ))}
          </div>
        ) : (
          <p class="text-sm text-muted-foreground">
            No posts are available right now.
          </p>
        )
      }
    </div>

    <div class="rounded-2xl border border-border/70 bg-card/80 p-4 sm:p-6">
      <div class="mb-4">
        <h2 class="text-xl font-semibold">Refine the list</h2>
        <p class="text-sm text-muted-foreground">
          These controls request a filtered or sorted list when you choose to
          use them.
        </p>
      </div>
      <BlogFilters
        initialBlogs={initialBlogs}
        availableCategories={BLOG_CATEGORIES}
        availableTags={availableTags}
        client:visible
      />
    </div>
  </main>
  <Footer />
</Layout>
