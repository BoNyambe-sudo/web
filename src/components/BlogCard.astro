---
import { Eye, Calendar } from "lucide-react";
import { formatDate } from "@/lib/formattedDate";
import { formatCompactNumber } from "@/lib/utils";

interface Props {
  blog: import("@/lib/api").BlogType;
  class?: string;
}
const { blog, class: className } = Astro.props;
const formattedDate = formatDate(blog.createdAt);
---

<div
  class={`relative mx-auto w-full max-w-auto h-auto pt-0 gap-4 overflow-hidden rounded-xl border bg-card ${className ?? ""}`}
>
  <a href={`/web/blog/${blog.slug}/`} class="hoverEffect group block">
    <img
      src={blog.thumbnail}
      class="relative z-20 aspect-video w-full object-cover transition-transform group-hover:scale-[1.02]"
      alt={blog.title}
      loading="lazy"
    />
  </a>

  <div class="p-4 space-y-3">
    <div class="flex items-cnter justify-between gap-4">
      <p class="font-semibold flex-1 text-sm border-b-2 pb-1 text-primary/60">
        {blog.category}
      </p>
      <div
        class="flex gap-2 items-center border-b-2 pb-1 flex-wrap text-sm text-muted-foreground"
      >
        <Calendar size={16} />
        <span class="font font-semibold text-sm"
          >{formattedDate}</span
        >
        {
          blog.views !== undefined && (
            <span class="flex items-center gap-1 text-muted-foreground text-xs">
              <Eye size={14} />
              {formatCompactNumber(blog.views)}
            </span>
          )
        }
      </div>
    </div>
    <a
      class="text-lg font-semibold hover:text-primary"
      href={`/web/blog/${blog.slug}/`}>{blog.title}</a
    >
  </div>
</div>
